# Frontend config — Vite exposes only VITE_-prefixed vars. Copy to .env to override.

# API base path used by the client. Default "/api" is proxied to the backend by
# the Vite dev server (see vite.config.ts), so cookies/CSRF are same-origin in
# dev. For a deployed build, set this to the API's real origin instead, e.g.
#   VITE_API_BASE=https://api.example.com
VITE_API_BASE=/api

# Where the Vite dev proxy forwards "/api" (only used by `npm run dev`). Change
# this if the local API listens somewhere other than the default.
# VITE_API_TARGET=http://localhost:8000
