# Copy to .env and adjust. Nothing here is secret — auth uses your Claude
# subscription via the Claude Code CLI, NOT an API key.
#
# IMPORTANT: do NOT set ANTHROPIC_API_KEY — that would route through paid API
# billing. Authenticate the CLI with your subscription instead (see README).

# RSS feed to summarize (one source).
FEED_URL=https://hnrss.org/frontpage

# How many of the latest items to include in the digest.
DIGEST_COUNT=10

# Where digests are written.
OUTPUT_DIR=output

# Claude model used by the Agent SDK. Override to save subscription quota,
# e.g. MODEL=claude-sonnet-4-6
MODEL=claude-opus-4-8

# Language for model-GENERATED text (digest summaries; brief summaries +
# perspective takes). Provenance — title/link/source/domain — is never translated.
# Default 简体中文; switch to e.g. 繁體中文 or English by changing this one value.
OUTPUT_LANGUAGE=简体中文

# --- Phase 2: database (Unit 1) ---
# Runtime database (PostgreSQL), SQLAlchemy URL form. Credentials live here / in
# env ONLY — never in code or Git. Replace the placeholder user/password.
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/agent

# Optional: run the data-layer tests against a throwaway PostgreSQL database
# instead of the default in-memory SQLite. Leave unset for fully offline tests.
# TEST_DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/agent_test

# --- Phase 3: control-plane API (Unit 1) ---
# Session-cookie signing key — the ONE secret here. Generate a strong random
# value; this .env is gitignored so it stays out of Git. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Add the Secure flag to cookies (set true only when served over HTTPS).
# Leave false on localhost, or the browser will drop the cookie over http.
COOKIE_SECURE=false

# Comma-separated browser origins allowed to call the API WITH credentials
# (the React dev server in Unit 2). Drives CORS; no effect on the offline tests.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Phase 2: email push (Unit 3) — OPTIONAL ---
# Leave unset to skip email (the digest is still saved). To enable delivery,
# uncomment and fill these. Credentials go in env / .env ONLY — never in Git.
# For Gmail, use an APP-SPECIFIC PASSWORD (not your account password).
# Setting only SOME of these is treated as a misconfiguration (logged loudly).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587                    # 465 = implicit SSL; anything else = STARTTLS
# SMTP_USERNAME=you@gmail.com
# SMTP_PASSWORD=your-app-specific-password
# SMTP_TO=you@gmail.com
# SMTP_FROM=you@gmail.com          # optional; defaults to SMTP_USERNAME
# SMTP_SUBJECT=Daily News Digest   # optional; defaults to "News Digest — <today>"

# --- Phase 10: coding workflow — OPTIONAL defaults ---
# Per-run task/workspace usually come from the CLI (--task/--workspace) or the
# web UI; these env values are only the fallback when neither is given.
# The workspace must be a git repo with a CLEAN tree (precondition).
# CODING_TASK=describe the change you want
# CODING_WORKSPACE=/absolute/path/to/a/git/repo
