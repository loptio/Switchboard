# Copy to .env and adjust. Nothing here is secret — auth uses your Claude
# subscription via the Claude Code CLI, NOT an API key.
#
# IMPORTANT: do NOT set ANTHROPIC_API_KEY — that would route through paid API
# billing. Authenticate the CLI with your subscription instead (see README).

# RSS feed to summarize (one source).
FEED_URL=https://hnrss.org/frontpage

# How many of the latest items to include in the digest.
DIGEST_COUNT=10

# Where digests are written.
OUTPUT_DIR=output

# Claude model used by the Agent SDK. Override to save subscription quota,
# e.g. MODEL=claude-sonnet-4-6
MODEL=claude-opus-4-8
